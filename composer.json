{
    "name": "jszdavid/laravel-world",
    "description": " A Laravel package which provides a list of the countries, states and cities based on nnjeim/world",
    "keywords": [
        "laravel",
        "countries",
        "cities",
        "states"
    ],
    "homepage": "https://github.com/jszd2022/laravel-world.git",
    "license": "MIT",
    "type": "laravel-package",
    "authors": [
        {
            "name": "J. Sz. David",
            "email": "99481700+jszd2022@users.noreply.github.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.0",
        "illuminate/support": "^8.0|^9.0|^10.0|^11.0|^12.0|13.0",
        "illuminate/database": "^8.0|^9.0|^10.0|^11.0|^12.0|13.0",
        "illuminate/http": "^8.0|^9.0|^10.0|^11.0|^12.0|13.0",
        "illuminate/validation": "^8.0|^9.0|^10.0|^11.0|^12.0|13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^6.0|^7.0|^8.0|^9.0",
        "phpunit/phpunit": "^9.0|^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "JSzD\\World\\": "src/",
            "JSzD\\World\\Database\\Seeders\\": "src/Database/Seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JSzD\\World\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "JSzD\\World\\WorldServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
